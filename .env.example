# Comma-separated upstream NTP server hostnames or addresses.
NTP_SERVERS=0.pool.ntp.org,1.pool.ntp.org,2.pool.ntp.org,3.pool.ntp.org

# Treat each NTP_SERVERS entry as a "server" or DNS "pool".
NTP_SOURCE_TYPE=pool

# Network allowed to query this server (for example, 192.168.1.0/24).
# Use "all" for every reachable client or leave empty to disable remote clients.
NTP_ALLOW=all

# Chrony logging severity: 0=information, 1=warning, 2=error, 3=fatal.
LOG_LEVEL=0

# IANA timezone used inside the container.
TZ=America/New_York

# Disable Chrony's client-access log when set to true.
NOCLIENTLOG=false

# Require Network Time Security from every configured upstream server.
ENABLE_NTS=false

# Allow Chrony to adjust the host clock; requires the SYS_TIME capability.
ENABLE_SYSCLK=true

# Prefer GPSD's high-precision SOCK source. Do not enable with KERNEL_PPS.
ENABLE_GPSD_SOCK=true

# Use kernel PPS locked to GPSD's NMEA source instead of GPSD SOCK.
ENABLE_KERNEL_PPS=false

# Prefer the selected u-blox GPS/PPS source when it agrees with other sources.
GPS_PREFER=true

# Device basenames mapped under /dev by Compose.
DEV_TTY=ttyAMA0
DEV_PPS=pps0

# Receiver-specific NMEA timing, used only with ENABLE_KERNEL_PPS=true.
NMEA_OFFSET=0.5
NMEA_DELAY=0.1

# Opt-in PHC/PTP source. Add its device mapping to Compose before enabling.
ENABLE_PTP=false
DEV_PTP=ptp0

# PHC-to-UTC correction in seconds; a TAI clock may require a negative offset.
PTP_OFFSET=0
